# Dependencias
node_modules/
**/node_modules/

# Variables de entorno (secretos)
.env
**/.env
.env.*
deploy/.env
deploy/.env.bak

# Datos persistentes VPS (no versionar)
data/uploads/*
!data/uploads/.gitkeep
data/backups/*
!data/backups/.gitkeep
data/sitio-videos/*
!data/sitio-videos/.gitkeep

# Build / caché
argo-frontend/dist/
argo-frontend/.angular/
**/dist/
*.log

# Subidas locales (certificados, firmas, recibos)
argo-backend/uploads/*
!argo-backend/uploads/.gitkeep

# Sistema
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# Cursor / assets temporales de chat (opcional; no incluir assets/ del móvil)
/assets/
!.gitkeep
.cursor/

# Sitio marketing: videos pesados (subir manualmente al VPS o usar CDN)
argo-sitio/public/videos/*.mp4
argo-sitio/public/imagenes/*.mp4

# APK del portal (copia de build; publicar vía ERP al desplegar)
argo-aula-virtual/public/apk/*.apk

# APK locales — generar con EAS; subir al VPS/portal desde el ERP (no versionar)
apk/*.apk
argo-mobile-aula/*.apk
argo-mobile-cajero/*.apk
**/*.apk
