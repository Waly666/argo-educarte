# Copiar a /opt/argo/deploy/.env en el VPS y ajustar JWT_SECRET (mismo que en local).
JWT_SECRET=CAMBIAR_POR_EL_DE_TU_ENV_LOCAL
JWT_EXPIRES=12h
PORT=3000
MONGO_URI=mongodb://argo-mongo:27017/argo
UPLOAD_DIR=uploads
# Vacío = URLs públicas según Host + X-Forwarded-Proto (recomendado con dos dominios)
PUBLIC_URL=
# URL canónica del portal aula (sitemap.xml y robots.txt)
PORTAL_SITE_URL=https://finstruvial.edu.co
# Producción HTTPS (tras deploy/nginx + certbot):
CORS_ORIGIN=https://app.finstruvial.edu.co,https://finstruvial.edu.co,https://www.finstruvial.edu.co
# Desarrollo / IP directa (solo pruebas):
# CORS_ORIGIN=http://72.60.175.120:8083,http://72.60.175.120:8084,http://72.60.175.120:8085
NODE_ENV=production
TZ=America/Bogota

# --- Seguridad Fase 1 (HTTPS ya activo en nginx) ---
TRUST_PROXY=1
# Registro portal: 0 = cerrado, 1 = abierto
PORTAL_REGISTRO_ABIERTO=1
# Rate limit login / buscar documento (15 min por IP)
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_BUSCAR_ALUMNO_MAX=15
# Cloudflare Turnstile (https://dash.cloudflare.com/) — vacío = desactivado
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
# TURNSTILE_ENABLED=1
# Mismo widget para finstruvial.edu.co y app.finstruvial.edu.co (hostnames en Cloudflare)

# --- 2FA TOTP (solo ERP web app.finstruvial.edu.co) ---
MFA_STAFF_REQUIRED=1
MFA_STAFF_WEB_ONLY=1
MFA_TOTP_ISSUER=ARGO Finstruvial
# TOTP_ENCRYPTION_KEY=opcional_clave_32_bytes_hex
# Desarrollo local: MFA_STAFF_REQUIRED=0

# --- Cuenta de soporte maestro / break-glass (acceso del proveedor) ---
# Admin que NO vive en la base de datos: credenciales aquí, distintas por instalación.
# Sobrevive a puesta en cero y restauración, no es visible ni editable desde la app,
# y SIEMPRE exige 2FA. Cada ingreso y acción quedan en la auditoría como el usuario indicado.
# Genérela con (escribe estas líneas solo, sin copiar a mano):
#   node scripts/soporte-maestro-setup.js --user soporte "TuClave" --env ../deploy/.env
# Luego: docker compose up -d --force-recreate argo-backend
# Nota: use SOPORTE_MASTER_PASSWORD (texto plano). NO use un hash bcrypt aquí: Docker
# Compose corrompe los "$" del hash al cargar el env_file. El TOTP es el factor fuerte.
# Deshabilitada por defecto. Para activarla, ponga ENABLED=true y complete las 3 variables.
SOPORTE_MASTER_ENABLED=false
# SOPORTE_MASTER_USER=soporte-argo
# SOPORTE_MASTER_PASSWORD=la_contraseña_en_texto_plano
# SOPORTE_MASTER_TOTP_SECRET=secreto_base32_del_authenticator

# --- Verificación correo registro aula virtual (solo portal) ---
# Activa si SMTP_* está configurado. 0 = registro directo sin código.
# PORTAL_EMAIL_VERIFY=1
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=aula@finstruvial.edu.co
# SMTP_PASS=
# SMTP_FROM="Finstruvial Aula Virtual <aula@finstruvial.edu.co>"
# PORTAL_EMAIL_FROM=opcional_si_diferente

# --- Respaldos (Sistema → Copias de seguridad) ---
# Carpeta de respaldos dentro del contenedor (montada en ./data/backups)
BACKUP_DIR=backups
# Cifrado AES-256 de los respaldos en reposo (ISO/IEC 27001 — control 8.24).
# Use una frase larga y guárdela fuera del servidor: sin ella NO se puede restaurar.
# BACKUP_CLAVE_CIFRADO=frase_secreta_larga_y_unica_para_esta_instalacion

# Factus sandbox (opcional — ver deploy/factus-sandbox.env.example)
# FACTUS_PROVEEDOR=factus
# FACTUS_AMBIENTE=sandbox
# FACTUS_BASE_URL=https://api-sandbox.factus.com.co
